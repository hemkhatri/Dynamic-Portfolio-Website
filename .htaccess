Options +FollowSymLinks
RewriteEngine On

# Explicitly set the base subdirectory folder for XAMPP
RewriteBase /hemkhatri.com.np/

# Route clean URLs matching /articles/slug-name internally to /articles/post.php?slug=slug-name
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^articles/([^/]+)$ articles/post.php?slug=$1 [L,QSA]
