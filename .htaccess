Options +FollowSymLinks -Indexes
RewriteEngine On

# 1. Point the base directly to your subfolder
RewriteBase /hemkhatri.com.np/

# Disable Apache's automatic physical trailing slash redirects for directories
DirectorySlash Off

# 2. Handle directory trailing slashes safely ONLY for real physical subfolders
# (This prevents exposing 'public/' in the browser URL bar)
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.*?[^/])$ /hemkhatri.com.np/$1/ [R=301,L]

# 3. Route specific clean URLs (Executes internally WITHOUT changing browser address text)
RewriteRule ^projects/?$ public/projects/projects.php [L,QSA]
RewriteRule ^articles/?$ public/articles/articles.php [L,QSA] 
RewriteRule ^articles/([^/]+)/?$ public/articles/post.php?slug=$1 [L,QSA]

# 4. Route root URL of your subfolder to your public index
RewriteRule ^$ public/index.php [L]

# 5. Route assets locally relative to the subfolder directory
RewriteCond %{REQUEST_URI} !^/public/
RewriteCond public/$1 -f [OR]
RewriteCond public/$1 -d
RewriteRule ^(.*)$ public/$1 [L]

# 6. Fallback for clean URLs/router
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/public/
RewriteRule ^(.*)$ public/index.php?/$1 [L,QSA]
